ENV=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/headlines

AUDIO_STORAGE_PROVIDER=local
# S3 / S3-compatible (set AUDIO_STORAGE_PROVIDER=s3 and fill these in for production)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=          # optional: R2, Spaces, MinIO
# S3_PUBLIC_BASE_URL=        # optional: CDN or R2 public domain

GNEWS_API_KEY=your-gnews-api-key-here
GNEWS_ENABLED=true

# LLM fallback categoriser — leave blank to disable fallback silently
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# FALLBACK_MODEL=claude-haiku-4-5-20251001   # override to swap model
# ENABLE_LLM_CATEGORISE_FALLBACK=true        # set false to disable Haiku categorisation

# TTS
TTS_PROVIDER=elevenlabs
# TTS_VOICE=JBFqnCBsd6RMkjVDRZzb      # default: ElevenLabs "George" (British male)
# TTS_MODEL=eleven_multilingual_v2     # default: multilingual v2
# TTS_AUDIO_FORMAT=mp3_44100_128       # default: 128kbps MP3
# ── ElevenLabs voice_settings (tune by ear; ranges 0.0–1.0) ──
# TTS_STABILITY=0.5                    # default: 0.5
# TTS_SIMILARITY_BOOST=0.75            # default: 0.75
# TTS_STYLE=0.15                       # default: 0.15
# TTS_USE_SPEAKER_BOOST=true           # default: true
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# OPENAI_API_KEY=                      # set if TTS_PROVIDER=openai

# Public API base URL — used to build absolute segment URLs returned in manifest responses.
# Must be reachable from iOS: use your Mac's LAN IP, not localhost.
# Find your current LAN IP: System Settings → Wi-Fi → Details → IP Address
#   or: ipconfig getifaddr en0
# When IP changes, update this value and restart the server.
PUBLIC_API_BASE_URL=http://192.168.1.x:8000

# Scheduled ingest
ENABLE_SCHEDULED_INGEST=false
